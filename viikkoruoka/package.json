{
  "name": "viikkoruoka",
  "version": "1.0.0",
  "private": true,
  "description": "Weekly grocery planner — single-package layout (server + client in one).",
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/src/index.js",
    "dev:client": "vite client",
    "build": "vite build client",
    "start": "node server/src/index.js",
    "db:migrate": "node server/src/db/migrate.js",
    "db:seed": "node server/src/db/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "vite": "^5.2.12"
  }
}
